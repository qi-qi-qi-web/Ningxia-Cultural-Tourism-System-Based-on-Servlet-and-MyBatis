<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.niit.mapper.OrderMapper">

    <resultMap id="OrderMap" type="com.niit.pojo.OrderMain">
        <id property="id" column="id"/>
        <result property="orderNo" column="order_no"/>
        <result property="userId" column="user_id"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="discountAmount" column="discount_amount"/>
        <result property="payAmount" column="pay_amount"/>
        <result property="pickupMethod" column="pickup_method"/>
        <result property="deliveryName" column="delivery_name"/>
        <result property="deliveryPhone" column="delivery_phone"/>
        <result property="deliveryAddress" column="delivery_address"/>
        <result property="status" column="status"/>
        <result property="paymentMethod" column="payment_method"/>
        <result property="paidAt" column="paid_at"/>
        <result property="shippedAt" column="shipped_at"/>
        <result property="completedAt" column="completed_at"/>
        <result property="remark" column="remark"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="userName" column="user_name"/>
    </resultMap>

    <select id="findAll" resultMap="OrderMap">
        SELECT om.*, u.username AS user_name
        FROM order_main om
        LEFT JOIN sys_user u ON om.user_id = u.id
        ORDER BY om.created_at DESC
    </select>

    <select id="findById" resultMap="OrderMap">
        SELECT om.*, u.username AS user_name
        FROM order_main om
        LEFT JOIN sys_user u ON om.user_id = u.id
        WHERE om.id = #{id}
    </select>

    <update id="updateStatus">
        UPDATE order_main SET status=#{status} WHERE id=#{id}
    </update>

    <update id="shipOrder">
        UPDATE order_main SET status='SHIPPED', shipped_at=NOW() WHERE id=#{id} AND status='PAID'
    </update>

    <update id="completeOrder">
        UPDATE order_main SET status='COMPLETED', completed_at=NOW() WHERE id=#{id}
    </update>
</mapper>
