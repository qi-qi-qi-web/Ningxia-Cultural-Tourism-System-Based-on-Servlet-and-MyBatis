<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.niit.mapper.PlatformLogMapper">

    <resultMap id="LogMap" type="com.niit.pojo.PlatformLog">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="userName" column="user_name"/>
        <result property="logType" column="log_type"/>
        <result property="targetType" column="target_type"/>
        <result property="targetId" column="target_id"/>
        <result property="targetName" column="target_name"/>
        <result property="detail" column="detail"/>
        <result property="ipAddress" column="ip_address"/>
        <result property="userAgent" column="user_agent"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findAll" resultMap="LogMap">
        SELECT * FROM sys_platform_log ORDER BY created_at DESC LIMIT 200
    </select>

    <select id="findById" resultMap="LogMap">
        SELECT * FROM sys_platform_log WHERE id = #{id}
    </select>
</mapper>
