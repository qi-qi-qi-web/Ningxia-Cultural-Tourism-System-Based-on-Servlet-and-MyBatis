<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE configuration
        PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>
    <properties resource="jdbc.properties"/>
    <typeAliases>
        <typeAlias type="com.niit.pojo.User" alias="User"/>
    </typeAliases>
    <environments default="development">
        <environment id="development">
            <transactionManager type="JDBC"/>
            <dataSource type="POOLED">
                <property name="driver" value="${driver}"/>
                <property name="url" value="${url}"/>
                <property name="username" value="${username}"/>
                <property name="password" value="${password}"/>
            </dataSource>
        </environment>
    </environments>
    <mappers>
        <mapper resource="com/niit/mapper/UserMapper.xml"/>
        <mapper resource="com/niit/mapper/NewsDynamicMapper.xml"/>
        <mapper resource="com/niit/mapper/OfficialNoticeMapper.xml"/>
        <mapper resource="com/niit/mapper/PlatformLogMapper.xml"/>
        <mapper resource="com/niit/mapper/SpecialtyMapper.xml"/>
        <mapper resource="com/niit/mapper/OrderMapper.xml"/>
        <mapper resource="com/niit/mapper/OrderItemMapper.xml"/>
        <mapper resource="com/niit/mapper/TravelGuideMapper.xml"/>
        <mapper resource="com/niit/mapper/GuideTagMapper.xml"/>
        <mapper resource="com/niit/mapper/CommentMapper.xml"/>
        <mapper resource="com/niit/mapper/HotelMapper.xml"/>
        <mapper resource="com/niit/mapper/ScenicSpotMapper.xml"/>
    </mappers>
</configuration>