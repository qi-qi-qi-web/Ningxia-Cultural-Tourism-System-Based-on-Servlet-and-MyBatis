<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.niit.mapper.OrderItemMapper">

    <resultMap id="OrderItemMap" type="com.niit.pojo.OrderItem">
        <id property="id" column="id"/>
        <result property="orderId" column="order_id"/>
        <result property="specialtyId" column="specialty_id"/>
        <result property="itemName" column="item_name"/>
        <result property="itemImage" column="item_image"/>
        <result property="quantity" column="quantity"/>
        <result property="unitPrice" column="unit_price"/>
        <result property="subtotal" column="subtotal"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO order_item (order_id, specialty_id, item_name, item_image, quantity, unit_price, subtotal)
        VALUES (#{orderId}, #{specialtyId}, #{itemName}, #{itemImage}, #{quantity}, #{unitPrice}, #{subtotal})
    </insert>

    <select id="findByOrderId" resultMap="OrderItemMap">
        SELECT * FROM order_item WHERE order_id = #{orderId}
    </select>

</mapper>
